VITE_API_URL=https://api.nius.cz
VITE_APP_URL=https://app.nius.cz

# Preferred: point this at a backend proxy that calls Mapy.cz server-side.
VITE_MAPY_SUGGEST_URL=

# If you use the direct Mapy.cz browser integration, this key is public in the JS bundle.
# Restrict it to production/staging domains in the Mapy.cz dashboard.
VITE_MAPY_API_KEY=

# Amplitude (EU project, same project as app.nius.cz for cross-domain funnels).
# Empty = analytics are a no-op. Tracking plan: nius/docs/analytics.md
VITE_AMPLITUDE_API_KEY=
